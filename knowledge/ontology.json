      "name": "PRODUCED_WORK",
      "domain": "PublicationEvent",
      "range": "Work",
      "event_type": null
    }
  ],
  "event_types": [
    {
      "name": "BirthEvent",
      "participants": [
        {"role": "person", "class": "Person"},
        {"role": "birth_place", "class": "Place"}
      ],
      "derived_relation": "BORN_IN"
    },
    {
      "name": "EducationEvent",
      "participants": [
        {"role": "student", "class": "Person"},
        {"role": "institution", "class": "Organization"}
      ],
      "derived_relation": "STUDIED_AT"
    },
    {
      "name": "EmploymentEvent",
      "participants": [
        {"role": "employee", "class": "Person"},
        {"role": "employer", "class": "Organization"}
      ],
      "derived_relation": "WORKED_AT"
    },
    {
      "name": "PublicationEvent",
      "participants": [
        {"role": "author", "class": "Person"},
        {"role": "work", "class": "Work"}
      ],
      "derived_relation": "AUTHORED"
    },
    {
      "name": "DeathEvent",
      "participants": [
        {"role": "person", "class": "Person"},
        {"role": "death_place", "class": "Place"}
      ],
      "derived_relation": "DIED_IN"
    },
    {
      "name": "ProposalEvent",
