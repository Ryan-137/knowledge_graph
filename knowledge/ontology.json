{
  "version": "2.0",
  "domain": "Alan Turing Knowledge Graph",
  "principles": {
    "mention_boundary": "本体只定义规范实体、最终关系和事件类型，不直接定义 mention 层输出。",
    "event_policy": "带明确时间过程的事实后续优先抽成事件，同时可以融合出简化关系事实。"
  },
  "classes": [
    {
      "name": "Entity",
      "parent": null,
      "attributes": ["entity_id", "canonical_name", "aliases", "description", "source_ids", "source_texts", "confidence", "external_ids"]
    },
    {
      "name": "Person",
      "parent": "Entity",
      "attributes": ["birth_date", "death_date"]
    },
    {
      "name": "Organization",
      "parent": "Entity",
      "attributes": ["org_type"]
    },
    {
      "name": "Place",
      "parent": "Entity",
      "attributes": ["place_type"]
    },
    {
      "name": "Work",
      "parent": "Entity",
      "attributes": ["publication_year", "work_type"]
    },
    {
      "name": "Concept",
      "parent": "Entity",
      "attributes": []
    },
    {
      "name": "Machine",
      "parent": "Entity",
      "attributes": ["model", "purpose"]
    },
    {
      "name": "Award",
      "parent": "Entity",
      "attributes": ["award_type", "awarding_body"]
    },
    {
      "name": "Event",
      "parent": "Entity",
      "attributes": ["event_id", "event_type", "time_text", "start_time", "end_time", "location_text", "source_ids", "source_texts", "confidence"]
    },
    {
      "name": "BirthEvent",
      "parent": "Event",
      "attributes": []
    },
    {
      "name": "EducationEvent",
      "parent": "Event",
      "attributes": []
    },
    {
      "name": "EmploymentEvent",
      "parent": "Event",
      "attributes": []
    },
    {
      "name": "PublicationEvent",
      "parent": "Event",
      "attributes": []
    },
    {
      "name": "DeathEvent",
      "parent": "Event",
      "attributes": []
    },
    {
      "name": "ProposalEvent",
      "parent": "Event",
      "attributes": []
    },
    {
      "name": "DesignEvent",
      "parent": "Event",
      "attributes": []
    },
    {
      "name": "HonorEvent",
      "parent": "Event",
      "attributes": []
    }
