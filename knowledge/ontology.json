    },
    {
      "type": "non_empty_array",
      "class": "Entity",
      "attribute": "source_ids"
    },
    {
      "type": "value_range",
      "class": "Entity",
      "attribute": "confidence",
      "min": 0.0,
      "max": 1.0
    },
    {
      "type": "value_range",
      "class": "Event",
      "attribute": "confidence",
      "min": 0.0,
      "max": 1.0
    },
    {
      "type": "relation_domain_range_check"
    },
    {
      "type": "event_role_required",
      "event_type": "BirthEvent",
      "roles": ["person", "birth_place"]
    },
    {
      "type": "event_role_required",
      "event_type": "EducationEvent",
      "roles": ["student", "institution"]
    },
    {
